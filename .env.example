NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional analytics remains completely unloaded unless this is a valid GA4 web
# measurement ID and the visitor affirmatively grants analytics consent.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Base64-encoded 32-byte AES key used only by the server for encrypted creator
# tax PDFs and Wise email-to-claim addresses. Generate outside chat/secrets logs.
SELLER_PRIVATE_DATA_ENCRYPTION_KEY=
SELLER_PRIVATE_DATA_ENCRYPTION_KEY_VERSION=1

# 44OS application email (server-only). Credentials do not enable delivery;
# email_delivery_controls remains the fail-closed database gate.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_CRON_SECRET=
RESEND_NEWSLETTER_TOPIC_ID=
RESEND_SMTP_PASSWORD=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SHIPPING_RATE_IDS=
STRIPE_AUTOMATIC_TAX_ENABLED=
STRIPE_MERCH_TAX_CODE=
STRIPE_MERCH_HAT_TAX_CODE=
STRIPE_MERCH_BAG_TAX_CODE=
STRIPE_BOOK_TAX_CODE=
STRIPE_MUSIC_TAX_CODE=
STRIPE_SAMPLE_PACK_TAX_CODE=
STRIPE_ACCEPTANCE_BUYER_ID=
STRIPE_ACCEPTANCE_ITEM_ID=
STRIPE_ACCEPTANCE_SESSION_ID=
STRIPE_ACCEPTANCE_EXPECTED_STATUS=paid
STRIPE_ACCEPTANCE_USE_LOCAL_SUPABASE=true
STRIPE_ACCEPTANCE_ALLOW_REMOTE=false
STRIPE_ACCEPTANCE_BUYER_EMAIL=m12-stripe-buyer@example.test
STRIPE_ACCEPTANCE_BUYER_PASSWORD=
PRINTFUL_PRIVATE_TOKEN=
PRINTFUL_STORE_ID=
PRINTFUL_STORE_CURRENCY=USD
PRINTFUL_WEBHOOK_SECRET=
PRINTFUL_ACCEPTANCE_USE_LOCAL_SUPABASE=true
NEXT_PUBLIC_PUBLIC_PURCHASES_AVAILABLE=false
# Development-only UI bypass for reviewing paid Store and Cart controls.
NEXT_PUBLIC_COMMERCE_TEST_MODE=false
